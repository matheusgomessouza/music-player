generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Track {
  id        String   @id @default(uuid())
  title     String
  artist    String
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
